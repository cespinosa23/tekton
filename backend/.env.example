# ─── Database ────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=tekton
DB_USER=tekton_user
DB_PASSWORD=CHANGE_ME_strong_password

# ─── Security ────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=CHANGE_ME_generate_a_long_random_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ─── Email (Gmail App Password) ──────────────────────────────
MAIL_USERNAME=your_gmail@gmail.com
MAIL_PASSWORD=your_16_char_app_password
MAIL_FROM=your_gmail@gmail.com

# ─── URLs ────────────────────────────────────────────────────
# Replace with your VM's public IP (or domain if you have one later)
FRONTEND_URL=http://YOUR_VM_IP

# CORS: allow requests from the frontend origin
ALLOWED_ORIGINS=http://YOUR_VM_IP
